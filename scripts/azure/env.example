# Create a private instance profile with:
#
#   scripts/azure/init-env.sh --profile example
#
# Do not put secrets in this file. Secrets and account credentials are read from
# the selected instances/NAME.local directory.

export EMAILCLEANER_INSTANCE_NAME="example"
export AZURE_LOCATION="centralus"
export AZURE_RESOURCE_GROUP="rg-emailcleaner-prod"
export AZURE_CONTAINERAPPS_ENV="cae-emailcleaner-prod"
export AZURE_JOB_NAME="caj-emailcleaner-prod"
export AZURE_LOG_WORKSPACE="law-emailcleaner-prod"
export AZURE_FILE_SHARE="emailcleaner-data"
export AZURE_STORAGE_MOUNT_NAME="emailcleaner-data"
export AZURE_IMAGE_NAME="emailcleaner"
export AZURE_ACR_RESOURCE_GROUP="rg-emailcleaner-prod"
export AZURE_CREATE_ACR="true"
export AZURE_SCAN_CRON="*/15 * * * *"
export AZURE_ACR_SKU="Basic"
export AZURE_JOB_TRIGGER_TYPE="Manual"
export AZURE_CPU="0.25"
export AZURE_MEMORY="0.5Gi"
export AZURE_BOOTSTRAP_IMAGE="mcr.microsoft.com/azuredocs/containerapps-helloworld:latest"
export AZURE_MAX_RUNTIME_SECONDS="3600"
export AZURE_REPLICA_TIMEOUT="3600"
export AZURE_REPLICA_RETRY_LIMIT="0"
export AZURE_PARALLELISM="1"
export AZURE_REPLICA_COMPLETION_COUNT="1"
export AZURE_PROVISION_SHARED_INFRASTRUCTURE="true"
export AZURE_DRY_RUN="false"

# Azure requires these names to be globally unique. init-env.sh generates
# stable names with an eight-digit suffix and stores them in the profile's
# azure.env.
export AZURE_UNIQUE_SUFFIX="12345678"
export AZURE_ACR_NAME="acremailcleaner${AZURE_UNIQUE_SUFFIX}"
export AZURE_STORAGE_ACCOUNT="stemcleaner${AZURE_UNIQUE_SUFFIX}"

# These names define which local secret values deploy.sh copies into Container
# Apps secrets. Update this list in the profile's azure.env if accounts change.
export AZURE_SECRET_ENV_VARS="OPENAI_API_KEY EMAIL_CLEANER_GMAIL_EMAIL_MAIN EMAIL_CLEANER_GMAIL_APP_PASSWORD_MAIN EMAIL_CLEANER_YAHOO_EMAIL_MAIN EMAIL_CLEANER_YAHOO_APP_PASSWORD_MAIN"
